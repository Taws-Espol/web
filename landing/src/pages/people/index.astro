---
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getMembers, toMemberViewModel } from '@utils/api';

const all = (await getMembers()).map(toMemberViewModel);
const current = all
  .filter((p) => p.group === 'current');
const alumni = all
  .filter((p) => p.group === 'alumni');
---

<Page title="Miembros" description={`Miembros del grupo de ${site.author.name}`}>
  <header class="post-header">
    <h1 class="post-title">miembros</h1>
  </header>

  {
    current.length > 0 && (
      <section class="mb-10">
        <h2
          class="mb-6 text-xl font-bold"
          style="color: var(--global-theme-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.25rem;"
        >
          Miembros actuales
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {current.map((person) => (
            <div class="person-card text-center">
              {
                <div style="width: 120px; height: 120px; border-radius: 50%; background-color: var(--global-divider-color); margin: 0 auto 0.75rem; display: flex; align-items: center; justify-content: center;">
                  <span style="font-size: 2rem; color: var(--global-text-color-light);">
                    {person.name.charAt(0)}
                  </span>
                </div>
              }

              <h3 class="text-sm font-semibold" style="color: var(--global-text-color);">
                {person.website ? (
                  <a
                    href={person.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    style="color: var(--global-text-color); text-decoration: none;"
                  >
                    {person.name}
                  </a>
                ) : (
                  person.name
                )}
              </h3>
              <p class="mt-0.5 text-xs" style="color: var(--global-text-color-light);">
                {person.role}
              </p>

              {/* Social icons */}
              <div class="mt-1 flex justify-center gap-2">
                {person.github && (
                  <a
                    href={`https://github.com/${person.github}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs"
                    style="color: var(--global-text-color-light); text-decoration: none;"
                    aria-label="GitHub"
                  >
                    gh
                  </a>
                )}
              </div>

              {person.description && (
                <p class="mt-1 text-xs" style="color: var(--global-text-color-light);">
                  {person.description}
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    alumni.length > 0 && (
      <section class="mb-10">
        <h2
          class="mb-6 text-xl font-bold"
          style="color: var(--global-theme-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.25rem;"
        >
          Alumni
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
          {alumni.map((person) => (
            <div class="flex items-center gap-3">
              <div style="width: 48px; height: 48px; border-radius: 50%; background-color: var(--global-divider-color); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                <span style="font-size: 1rem; color: var(--global-text-color-light);">{person.name.charAt(0)}</span>
              </div>
              <div>
                <p class="text-sm font-semibold" style="color: var(--global-text-color);">
                  {person.website ? (
                    <a
                      href={person.website}
                      target="_blank"
                      rel="noopener noreferrer"
                      style="color: var(--global-text-color); text-decoration: none;"
                    >
                      {person.name}
                    </a>
                  ) : (
                    person.name
                  )}
                </p>
                <p class="text-xs" style="color: var(--global-text-color-light);">
                  {person.role}
                </p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {all.length === 0 && <p style="color: var(--global-text-color-light);">Aún no hay miembros.</p>}
</Page>
