---
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getProjects, toProjectViewModel, type ProjectViewModel } from '@utils/api';
import { withBase } from '@utils/base';

export async function getStaticPaths() {
  const projects = (await getProjects()).map(toProjectViewModel);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props as { project: ProjectViewModel };
const githubUrl = project.github ? `https://github.com/${project.github}` : undefined;
const ogImagePath = project.img
  ? new URL(project.img, site.url).toString()
  : new URL(`${site.base}/og/project/${project.id}.png`, site.url).toString();
---

<Page title={project.title} description={project.description} image={ogImagePath}>
  <div class="post">
    <nav aria-label="Breadcrumb" class="breadcrumb-nav">
      <a href={`${site.base}/projects/`} class="breadcrumb-link">← Proyectos</a>
    </nav>

    <header class="post-header">
      <h1 class="post-title">{project.title}</h1>
      {project.description && <p class="post-description">{project.description}</p>}

      {(githubUrl || project.url) && (
        <div class="project-links">
          {githubUrl && (
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="project-btn project-btn--primary">
              GitHub
            </a>
          )}
          {project.url && (
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-btn project-btn--secondary">
              Sitio web
            </a>
          )}
        </div>
      )}
    </header>

    <article>
      {project.img && (
        <div class="project-hero">
          <img src={withBase(project.img)} alt={project.imgAlt ?? project.title} loading="eager" class="img-fluid z-depth-1 rounded" />
        </div>
      )}
      <div class="prose" id="project-content">
        <p>{project.description}</p>
      </div>
    </article>
  </div>
</Page>
