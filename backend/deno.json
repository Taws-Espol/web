{
  "tasks": {
    "dev": "deno run --watch -P=development --env-file=../.env src/main.ts",
    "start": "deno run -P=deployment src/main.ts",
    "test": "deno test -P=development tests/main_tests.ts",
    "check": "deno check src/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint src/",
    "import:members": "deno run -P=development scripts/import-members-csv.ts",
    "db:generate": "deno run -A npm:drizzle-kit generate",
    "db:migrate": "deno run -A npm:drizzle-kit migrate",
    "db:push": "deno run --env-file=../.env -A npm:drizzle-kit push"
  },
  "imports": {
    "@asteasolutions/zod-to-openapi": "npm:@asteasolutions/zod-to-openapi@^8.5.0",
    "@scalar/express-api-reference": "npm:@scalar/express-api-reference@^0.9.14",
    "@std/assert": "jsr:@std/assert@1",
    "drizzle-kit": "npm:drizzle-kit@^0.31.10",
    "drizzle-orm": "npm:drizzle-orm@^0.45.2",
    "express": "npm:express@^5.2.1",
    "pg": "npm:pg@^8.20.0",
    "zod": "npm:zod@^4.4.3",
    "@shared/": "./src/shared/",
    "@config/": "./src/config/",
    "@events/": "./src/modules/events/",
    "@members/": "./src/modules/members/",
    "@projects/": "./src/modules/projects/",
    "@users/": "./src/modules/users/"
  },
  "permissions": {
    "development": {
      "env": true,
      "net": true,
      "read": true,
      "write": true,
      "run": {
        "allow": true,
        "deny": [
          "rm",
          "sudo"
        ]
      }
    },
    "deployment": {
      "env": true,
      "net": true,
      "read": true,
      "write": false,
      "run": false,
      "ffi": false,
      "sys": false,
      "import": false
    }
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 80,
    "semiColons": true,
    "singleQuote": true,
    "useTabs": false,
    "trailingCommas": "never"
  }
}
